#!/usr/bin/env bash
# opus-mind — CLI escape hatch for the Claude Code skill.
#
# PRIMARY UX: Invoke the skill inside Claude Code. Claude reads SKILL.md,
# runs these scripts with `--json` under the hood, and synthesizes a
# prose response with line refs and a ranked action plan. That's the
# product.
#
# This bash wrapper is the SECONDARY surface — it exists for:
#   - the git pre-commit hook (install-hook.sh wires it into .git/hooks)
#   - CI gates (GitHub Actions, Jenkins, etc.)
#   - standalone CLI users who are not inside Claude Code and want a
#     quick score without reading JSON
#
# If you are inside Claude Code, DO NOT run this by hand. The skill
# knows how to orchestrate the helpers better than a script can.
#
# Two products:
#
#   LINT  — for builders (CLAUDE.md / SKILL.md / .cursorrules / chatbot system prompts)
#           safety, rule conflicts, policy tier design, refusal structure
#
#   BOOST — for users (Claude chat / ChatGPT / Cursor single prompts)
#           task clarity, output format, length, audience, examples, constraints
#
# Usage:
#   opus-mind lint audit       <path>                     score 11 invariants
#   opus-mind lint plan        <path>                     required-primitive TODO
#   opus-mind lint fix         <path> [--add NAMES]       deterministic rewrite / inject
#   opus-mind lint decode      <path>                     label present primitives
#   opus-mind lint self-audit                             informational (no longer gated)
#
#   opus-mind boost check      <prompt_or_path>           slot coverage report
#   opus-mind boost ask        <prompt_or_path>           questions for missing slots
#   opus-mind boost expand     <prompt_or_path> [flags]   emit composition prompt
#
# Legacy top-level (backward compat with v0.1 and the pre-commit hook):
#   opus-mind audit / plan / fix / decode / draft / symptom / crosscheck / self-audit

set -euo pipefail

here="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
py="${PYTHON:-python3}"

usage() {
    cat <<'EOF'
opus-mind — compile a prompt like a program.

Two products:

  LINT  — for builders (production agent prompts)
    opus-mind lint audit      <path>             score 11 invariants
    opus-mind lint plan       <path>             what's missing for this domain
    opus-mind lint fix        <path> [--add ..]  rewrite / inject skeleton
    opus-mind lint decode     <path>             label 12 primitives present
    opus-mind lint self-audit                    audit this skill's SKILL.md

  BOOST — for users (single prompts to Claude / ChatGPT / Cursor)
    opus-mind boost check     <text|path>        slot coverage (7 slots)
    opus-mind boost ask       <text|path>        questions to fill empty slots
    opus-mind boost expand    <text|path> [..]   concrete prompt from answers

Other:
    opus-mind crosscheck <path>                  LLM crosscheck on lint audit
    opus-mind symptom "<query>"                  symptom → primitive pointer
    opus-mind help                               this message

Docs: skills/opus-mind/SKILL.md
EOF
}

dispatch_lint() {
    local sub="${1:-help}"
    [ "$#" -gt 0 ] && shift || true
    case "$sub" in
        audit)       exec "$py" "$here/audit.py" "$@" ;;
        plan)        exec "$py" "$here/plan.py" "$@" ;;
        fix)         exec "$py" "$here/fix.py" "$@" ;;
        decode)      exec "$py" "$here/decode.py" "$@" ;;
        draft)       exec "$py" "$here/draft.py" "$@" ;;
        seed)        exec "$py" "$here/seed.py" "$@" ;;
        critic)      exec bash "$here/critic.sh" "$@" ;;
        self-audit)  exec "$py" "$here/audit.py" --self ;;
        help|--help|-h|"")
            echo "opus-mind lint — for builders (agent / system prompts)"
            echo
            echo "  audit <path>                    score 11 invariants"
            echo "  plan <path>                     required-primitive TODO"
            echo "  fix <path> [--add NAMES]        rewrite / inject skeleton"
            echo "  decode <path>                   label 12 primitives present"
            echo "  seed --type <name> [-o file]    emit a starter skeleton"
            echo "  critic <path>                   audit → fix → re-audit loop"
            echo "  self-audit                      informational — score SKILL.md"
            ;;
        *) echo "unknown lint subcommand: $sub" >&2; exit 2 ;;
    esac
}

dispatch_boost() {
    local sub="${1:-help}"
    [ "$#" -gt 0 ] && shift || true
    case "$sub" in
        check|ask|expand)
            exec "$py" "$here/boost.py" "$sub" "$@"
            ;;
        help|--help|-h|"")
            echo "opus-mind boost — for users (single prompts)"
            echo
            echo "  check <prompt|path>           slot coverage (7 slots)"
            echo "  ask <prompt|path>             questions for empty slots"
            echo "  expand <prompt|path> [flags]  concrete prompt from answers"
            echo
            echo "expand flags: --length / --format / --context / --constraints"
            echo "              --task / --few-shot / --clarify / --answers FILE"
            echo
            echo "expand emits the composition prompt. In a Claude Code"
            echo "session, the current Claude applies it directly. Outside,"
            echo "paste the emitted text into any LLM. No API key used."
            ;;
        *) echo "unknown boost subcommand: $sub" >&2; exit 2 ;;
    esac
}

cmd="${1:-help}"
[ "$#" -gt 0 ] && shift || true

case "$cmd" in
    # Two-product dispatch
    lint)   dispatch_lint "$@" ;;
    boost)  dispatch_boost "$@" ;;

    # Legacy top-level (pre-commit hook + v0.1 users)
    audit)       exec "$py" "$here/audit.py" "$@" ;;
    plan)        exec "$py" "$here/plan.py" "$@" ;;
    fix)         exec "$py" "$here/fix.py" "$@" ;;
    decode)      exec "$py" "$here/decode.py" "$@" ;;
    draft)       exec "$py" "$here/draft.py" "$@" ;;
    symptom)     exec "$py" "$here/symptom_search.py" "$@" ;;
    benchmark)   exec "$py" "$here/benchmark.py" "$@" ;;
    seed)        exec "$py" "$here/seed.py" "$@" ;;
    critic)      exec bash "$here/critic.sh" "$@" ;;
    crosscheck)
        # Emit the LLM crosscheck review prompt. Claude (in Claude Code)
        # applies it in-session; standalone users paste into any LLM.
        exec "$py" "$here/audit.py" "$@" --crosscheck
        ;;
    self-audit)  exec "$py" "$here/audit.py" --self ;;

    help|--help|-h|"") usage ;;
    *) echo "unknown command: $cmd" >&2; usage >&2; exit 2 ;;
esac
