#!/usr/bin/env bash
# opus-mind — single CLI entry for audit / decode / fix / draft / plan / symptom.
#
# Usage:
#   opus-mind audit      <path> [--json] [--stylebook] [--crosscheck prompt|exec]
#   opus-mind decode     <path> [--json]
#   opus-mind plan       <path> [--json]
#   opus-mind fix        <path> [--apply] [--add <names>] [-o out.md]
#   opus-mind draft      [-o out.md] [--answers answers.json]
#   opus-mind symptom    "<natural-language symptom>" [-n N]
#   opus-mind crosscheck <path> [--exec]
#   opus-mind self-audit
#   opus-mind help

set -euo pipefail

here="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
py="${PYTHON:-python3}"

usage() {
    cat <<EOF
opus-mind — compile a prompt like a program.

  audit <path>        score against 11 invariants (I1-I11)
  decode <path>       label which of 12 primitives are present
  plan <path>         TODO checklist: required primitives missing for this prompt
  fix <path>          deterministic slop rewriter (--add <name> injects skeleton)
  draft [-o file]     interactive skeleton builder
  symptom <query>     symptom → source evidence + primitive pointer
  crosscheck <path>   emit LLM crosscheck prompt (add --exec to call API)
  self-audit          audit this skill's own SKILL.md
  help                show this message

Docs: skills/opus-mind/SKILL.md
EOF
}

cmd="${1:-help}"
[ "$#" -gt 0 ] && shift || true

case "$cmd" in
    audit)       exec "$py" "$here/audit.py" "$@" ;;
    decode)      exec "$py" "$here/decode.py" "$@" ;;
    plan)        exec "$py" "$here/plan.py" "$@" ;;
    fix)         exec "$py" "$here/fix.py" "$@" ;;
    draft)       exec "$py" "$here/draft.py" "$@" ;;
    symptom)     exec "$py" "$here/symptom_search.py" "$@" ;;
    crosscheck)
        # route to audit.py --crosscheck; --exec or default prompt
        mode="prompt"
        filtered=()
        for arg in "$@"; do
            if [ "$arg" = "--exec" ]; then
                mode="exec"
            else
                filtered+=("$arg")
            fi
        done
        exec "$py" "$here/audit.py" "${filtered[@]}" --crosscheck "$mode"
        ;;
    self-audit)  exec "$py" "$here/audit.py" --self ;;
    help|--help|-h|"") usage ;;
    *) echo "unknown command: $cmd" >&2; usage >&2; exit 2 ;;
esac
