#!/usr/bin/env bash
# opus-mind — single CLI entry for audit / decode / fix / draft.
#
# Usage:
#   opus-mind audit  <path> [--json]
#   opus-mind decode <path> [--json]
#   opus-mind fix    <path> [--apply] [-o out.md]
#   opus-mind draft  [-o out.md] [--answers answers.json]
#   opus-mind self-audit
#   opus-mind help

set -euo pipefail

here="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
py="${PYTHON:-python3}"

usage() {
    cat <<EOF
opus-mind — compile a prompt like a program.

  audit <path>        score against 6 invariants
  decode <path>       label which primitives are present
  fix <path>          deterministic slop rewriter
  draft [-o file]     interactive skeleton builder
  self-audit          audit this skill's own SKILL.md
  help                show this message

Docs: skills/opus-mind/SKILL.md
EOF
}

cmd="${1:-help}"
[ "$#" -gt 0 ] && shift || true

case "$cmd" in
    audit)       exec "$py" "$here/audit.py" "$@" ;;
    decode)      exec "$py" "$here/decode.py" "$@" ;;
    fix)         exec "$py" "$here/fix.py" "$@" ;;
    draft)       exec "$py" "$here/draft.py" "$@" ;;
    self-audit)  exec "$py" "$here/audit.py" --self ;;
    help|--help|-h|"") usage ;;
    *) echo "unknown command: $cmd" >&2; usage >&2; exit 2 ;;
esac
